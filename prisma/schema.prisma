generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  BKASH
  NAGAD
  ROCKET
  CARD
  PAYPAL
  STRIPE
  SSLCOMMERZ
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  fullName      String
  phone         String?
  avatarUrl     String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  reviews       ProductReview[]
  wishlists    Wishlist[]
  carts         Cart[]
  addresses     Address[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  nameBn      String?
  slug        String    @unique
  description String?
  imageUrl    String?
  color       String?
  icon        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  name        String
  nameBn      String?
  slug        String    @unique
  description String?
  descriptionBn String?
  price       Float
  oldPrice    Float?
  imageUrl    String?
  images      String[]
  inStock     Boolean   @default(true)
  stock       Int       @default(0)
  sku         String?   @unique
  featured    Boolean   @default(false)
  status      String    @default("active")
  sortOrder   Int       @default(0)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        String[]
  
  orderItems  OrderItem[]
  reviews     ProductReview[]
  wishlists  Wishlist[]
  carts       Cart[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProductReview {
  id          String    @id @default(cuid())
  rating      Int
  comment     String?
  isApproved  Boolean   @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestName       String?
  guestPhone      String?
  guestEmail      String?
  subtotal        Float
  shippingCost    Float         @default(0)
  discount        Float         @default(0)
  total           Float
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentTrxId    String?
  shippingAddress String?
  notes           String?
  
  items           OrderItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float
  createdAt   DateTime @default(now())
}

model Cart {
  id          String    @id @default(cuid())
  userId      String?
  sessionId   String?
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int       @default(1)
  user        User?     @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model Wishlist {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([userId, productId])
}

model Address {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  phone       String
  address     String
  city        String?
  district    String?
  division    String?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Tool {
  id          String    @id @default(cuid())
  title       String
  titleBn     String
  link        String
  icon        String
  buttonText  String
  buttonTextBn String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Course {
  id          String    @id @default(cuid())
  titleEn     String
  titleBn     String
  descriptionEn String
  descriptionBn String
  link        String
  imageUrl    String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id          String    @id @default(cuid())
  title       String
  titleBn     String
  description  String
  descriptionBn String
  icon        String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteSettings {
  id            String   @id @default("site_settings")
  shopNameEn    String?  @default("SB Mobile Shop")
  shopNameBn    String?  @default("SB মোবাইল শপ")
  phone         String?  @default("01711791122")
  phone2        String?  @default("01773243748")
  email         String?  @default("sbmobileshop24@gmail.com")
  addressEn     String?
  addressBn     String?
  whatsapp      String?
  logoUrl       String?
  faviconUrl    String?
  
  heroBgUrl     String?
  heroTitle     String?  @default("SB Mobile Shop")
  heroSubtitleEn String?  @default("Come and visit here for accessories & mobile repair")
  heroSubtitleBn String?  @default("আমাদের এখানে আসুন এক্সেসরিজ ও মোবাইল রিপেয়ারের জন্য")
  heroTaglineEn String?   @default("Home Delivery All Over Bangladesh")
  heroTaglineBn String?   @default("সারাদেশে হোম ডেলিভারি")
  heroCtaTextEn String?   @default("Order Now")
  heroCtaTextBn String?   @default("এখনই অর্ডার করুন")
  heroVideoUrl  String?
  
  footerAboutEn String?
  footerAboutBn String?
  facebookUrl   String?
  messengerUrl  String?
  youtubeUrl   String?
  instagramUrl String?
  googleMapsUrl String?
  
  bannerTextEn String?
  bannerTextBn String?
  bannerEnabled Boolean  @default(true)
  
  noticeTextEn String?
  noticeTextBn String?
  noticeEnabled Boolean @default(false)
  
  bkashNumber   String?
  nagadNumber   String?
  rocketNumber  String?
  bkashEnabled  Boolean  @default(true)
  nagadEnabled  Boolean  @default(true)
  rocketEnabled Boolean  @default(true)
  
  showHero       Boolean  @default(true)
  showCategories Boolean  @default(true)
  showServices   Boolean  @default(true)
  showProducts   Boolean  @default(true)
  showPayment    Boolean  @default(true)
  showCourses    Boolean  @default(true)
  showTools      Boolean  @default(true)
  showWhyUs      Boolean  @default(true)
  showAbout      Boolean  @default(true)
  showContact    Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  discountType String   @default("PERCENTAGE")
  discountValue Float
  minOrderAmount Float?
  maxDiscountAmount Float?
  usageLimit  Int?
  usedCount   Int       @default(0)
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DeliveryZone {
  id          String    @id @default(cuid())
  name        String
  district    String
  shippingCost Float   @default(0)
  estimatedDays String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PageSeo {
  id          String    @id @default(cuid())
  page        String    @unique
  titleEn     String?
  titleBn     String?
  descriptionEn String?
  descriptionBn String?
  keywords    String?
  ogImageUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
